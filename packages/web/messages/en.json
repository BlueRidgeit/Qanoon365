  "guide": {
    "title": "User Guide",
    "subtitle": "Learn how to use the platform effectively",
    "tableOfContents": "Table of Contents",
    "gettingStarted": "Getting Started",
    "gettingStartedDesc": "Welcome to the Qanoon365 Legal Intelligence Platform. This guide will help you navigate and make the most of the system's features.",
    "gettingStartedLogin": "Log in with your firm email and password. Your administrator will have set up your account with the appropriate role and permissions.",
    "gettingStartedNav": "The sidebar on the left provides access to all sections. You can collapse it for more screen space using the toggle at the bottom. The platform supports both English and Arabic — switch languages using the globe icon.",
    "gettingStartedRoles": "Your access level depends on your role: Administrator (full access), Partner (approvals and oversight), Compliance Officer (KYC and conflict checks), Lawyer (case management), or Business Development (enquiries and pipeline).",
    "firmDashboardGuide": "Firm Dashboard",
    "firmDashboardDesc": "The dashboard is your at-a-glance overview of the firm's operations. It displays key performance indicators including active instructions, open matters, conflict reviews pending clearance, and KYC compliance rates. The instruction pipeline chart shows the flow from new enquiries through to instructed matters. Recent activity is shown at the bottom.",
    "enquiriesGuide": "New Enquiries",
    "enquiriesDesc": "This is where new business enquiries are logged and tracked. When a potential client contacts the firm, create a new enquiry with the subject, case type, jurisdiction, and urgency level. As you qualify the enquiry, update its status from Received through Initial Response, Qualified, and finally to Instructed (or Declined). Each enquiry can include an estimated fee value and case summary.",
    "pipelineGuide": "Engagement Pipeline",
    "pipelineDesc": "The engagement pipeline tracks opportunities from initial enquiry through to formal instruction. Create engagements linked to clients, assign practice areas and fee arrangements, and move them through stages: Initial Enquiry, Consultation, Fee Proposal, Retainer Sent, and finally Instructed or Not Instructed. The pipeline view shows aggregate statistics including total estimated fees and instruction rates.",
    "mattersGuide": "Active Matters",
    "mattersDesc": "Once a client is formally instructed, the engagement becomes an active matter. Matters are assigned unique reference numbers, linked to clients and practice areas, and tracked through their lifecycle. Use the search to find matters by number or name.",
    "clientsGuide": "Client Directory",
    "clientsDesc": "The client directory maintains records for all firm clients — individuals, companies, and government entities. Each client profile includes contact details, industry, risk rating, and KYC status. Clients are linked to their matters, engagements, and contacts.",
    "contactsGuide": "Counsel & Contacts",
    "contactsDesc": "Manage contacts associated with your clients. Contacts include opposing counsel, client representatives, and other relevant parties. Add contacts through individual client pages.",
    "conflictsGuide": "Conflict Checks",
    "conflictsDesc": "Conflict of interest reviews are automatically triggered when new engagements are created. The AI system analyzes CRM data and court records to identify potential conflicts. Reviews awaiting Partner clearance are highlighted. Resolve conflicts by marking them as Cleared, Conflict Identified, or Waiver Granted with supporting notes.",
    "kycGuide": "KYC & Compliance",
    "kycDesc": "Track Know Your Client verification for all clients. Create KYC records, assign risk ratings, set ID expiry dates, and move clients through the verification workflow: Not Started, Documents Requested, Under Review, Verified, or Expired. The dashboard shows overall compliance rates.",
    "enforcementGuide": "Enforcement",
    "enforcementDesc": "The enforcement module manages court execution files and criminal complaints. Track execution files by court, monitor collection amounts, and manage automated follow-up emails to courts. Criminal complaints are tracked from filing through investigation to prosecution referral. The follow-up system can send automated status inquiry emails to court registries on a configurable schedule.",
    "intelligenceGuide": "AI Legal Research",
    "intelligenceDesc": "The Court Intelligence Engine provides AI-powered legal research across four query types: Litigant Profile Analysis (analyze a party's litigation history), Comparable Precedents (find similar cases by practice area and jurisdiction), Precedent & Case Law (research legal principles), and Opposing Counsel Intelligence (analyze opposing firms or lawyers). Results include confidence scores, key findings, risk factors, and actionable recommendations.",
    "documentsGuide": "Document Vault",
    "documentsDesc": "Securely store and manage documents linked to matters, clients, engagements, and other entities. Upload files with categories including Correspondence, Court Filings & Pleadings, Legal Memoranda, Agreements & Contracts, and KYC Documents. Documents are versioned and searchable.",
    "settingsGuide": "Firm Settings",
    "settingsDesc": "Configure your personal profile, choose your preferred theme (Light, Dark, or System), and view platform information including version and build details."
  }
}
